# step 2: Grounded Generation and Controlled Refusal Engine

import torch
import torch.nn as nn
import torch.nn.functional as F

class GroundedRefusalReportGenerator(nn.Module):
    def __init__(self, vocab_size=5000, feature_dim=768, hidden_dim=512):
        super().__init__()
        # Visual Feature Processor (Expects tokenized patch outputs from ViT/BiomedCLIP)
        self.visual_projection = nn.Linear(feature_dim, hidden_dim)
        
        # Parallel Multi-Head Prediction Layers
        self.token_head = nn.Linear(hidden_dim, vocab_size)
        self.grounding_head = nn.Linear(hidden_dim, 4) # Normalized Spatial coordinates [Xmin, Ymin, Xmax, Ymax]
        self.confidence_head = nn.Linear(hidden_dim, 1) # Probability score evaluating clinical evidence

    def generate_with_constraints(self, visual_patches, max_length=60, confidence_alpha=0.88):
        """
        Implements an evidence-gated decoding loop. 
        Halts and refuses generation if the spatial feature vectors present high uncertainty.
        """
        batch_size = visual_patches.size(0)
        projected_features = self.visual_projection(visual_patches.mean(dim=1)) # Pool patches
        
        generated_report = []
        evidence_logs = []
        
        for step in range(max_length):
            token_logits = self.token_head(projected_features)
            bbox_coords = torch.sigmoid(self.grounding_head(projected_features))
            evidence_score = torch.sigmoid(self.confidence_head(projected_features))
            
            # Extract highest probability token
            probs = F.softmax(token_logits, dim=-1)
            max_prob, target_token = torch.max(probs, dim=-1)
            
            # Enforce Controlled Refusal Constraint
            if evidence_score.item() < confidence_alpha:
                generated_report.append("[INSUFFICIENT_EVIDENCE_REFUSAL]")
                evidence_logs.append({
                    "step": step,
                    "status": "REFUSED",
                    "reason": f"Evidence confidence {evidence_score.item():.4f} fell below alpha threshold {confidence_alpha}"
                })
                break # Hard exit to prevent hallucinated fill-in phrases
                
            generated_report.append(target_token.item())
            evidence_logs.append({
                "step": step,
                "status": "GROUNDED",
                "predicted_coordinates": bbox_coords.squeeze(0).tolist(),
                "evidence_confidence": evidence_score.item()
            })
            
            # Simulate autoregressive sequence development via feature mapping
            projected_features = projected_features * 0.95 
            
        return generated_report, evidence_logs
